APP_NAME="Ticketing System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (shared _infra MySQL 8.0) ──────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ticketing
DB_USERNAME=root
DB_PASSWORD=rootsecret

# ── Session (Redis) ──────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache (Redis) ────────────────────────────────────
CACHE_STORE=redis

# ── Queue (Redis — required for Horizon) ─────────────
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (shared _infra Mailpit) ─────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@ticketing.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Storage ──────────────────────────────────────────
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

VITE_APP_NAME="${APP_NAME}"
